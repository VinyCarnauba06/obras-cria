PORT=5000
NODE_ENV=production
HOST=0.0.0.0

MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/obras-db

CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=sua_api_secret

# Lista de origens permitidas separadas por vírgula (sem espaço após a vírgula)
# Produção: URL exata do frontend no Render
# Dev: http://127.0.0.1:8080,http://localhost:8080
CORS_ORIGIN=https://obras-cria-frontend.onrender.com